# --- Qwen (Hugging Face Inference Providers router) ---

# HF's unified OpenAI-compatible router. Confirmed current.
QWEN_API_BASE=https://router.huggingface.co/v1

# A Hugging Face token with the "Make calls to Inference Providers"
# permission enabled. A plain read token will NOT work.
QWEN_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LANDMINE: the HF router requires a CONCRETE provider suffix on the model name
# telling it which backend serves the request. Omit the suffix and the call
# fails; use the ":auto" policy and THIS OpenAI-compatible endpoint rejects it
# with 400 model_not_supported. As of the last check, Qwen/Qwen3-VL-30B-A3B-
# Instruct is served live only by :novita and :featherless-ai (NOT :together /
# :fireworks-ai). Verify current providers at:
#   https://huggingface.co/api/models/Qwen/Qwen3-VL-30B-A3B-Instruct?expand[]=inferenceProviderMapping
QWEN_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct:novita

# Set to 1 to forbid network calls: a cache miss raises instead of calling
# the network. Leave unset (or 0) for normal record/replay behavior.
QWEN_OFFLINE=0
